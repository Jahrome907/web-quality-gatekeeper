{
  "timeouts": {
    "navigationMs": 15000,
    "actionMs": 5000,
    "waitAfterLoadMs": 500
  },
  "playwright": {
    "viewport": {
      "width": 1280,
      "height": 720
    },
    "userAgent": "wqg-fixture/3.1.5",
    "locale": "en-US",
    "colorScheme": "light"
  },
  "screenshots": [
    {
      "name": "home",
      "path": "@target",
      "fullPage": true
    }
  ],
  "lighthouse": {
    "budgets": {
      "performance": 0.8,
      "lcpMs": 2500,
      "cls": 0.1,
      "tbtMs": 200
    },
    "formFactor": "desktop"
  },
  "visual": {
    "threshold": 0.01
  },
  "toggles": {
    "perf": false,
    "visual": false
  }
}
