{
  "name": "web-quality-gatekeeper",
  "version": "3.2.0",
  "description": "Quality gate CLI and GitHub Action for Playwright, axe-core, Lighthouse, and visual diffs.",
  "author": "Jahrome907",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jahrome907/web-quality-gatekeeper.git"
  },
  "homepage": "https://jahrome907.github.io/web-quality-gatekeeper/",
  "bugs": {
    "url": "https://github.com/Jahrome907/web-quality-gatekeeper/issues"
  },
  "keywords": [
    "quality",
    "accessibility",
    "a11y",
    "lighthouse",
    "playwright",
    "visual-regression",
    "github-action",
    "axe-core",
    "web-performance",
    "ci"
  ],
  "type": "module",
  "bin": {
    "wqg": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js",
    "./configs/*": "./configs/*",
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "configs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "engines:check": "node scripts/ci/assert-node-engine.mjs",
    "contracts:check": "vitest run tests/summary.contract-drift.test.ts tests/prRiskLedger.test.ts",
    "check": "npm run typecheck && npm run lint && npm run test",
    "validate:full": "npm run engines:check && npm run lint && npm run typecheck && npm run build && npm test && npm run security:audit",
    "smoke:pack": "node scripts/ci/pack-smoke.mjs",
    "smoke:action": "node scripts/ci/local-action-smoke.mjs",
    "release:dry-run": "node scripts/ci/release-dry-run.mjs",
    "security:audit": "node scripts/enforce-runtime-audit.mjs --exceptions configs/security/audit-exceptions.json",
    "python:smoke": "node scripts/ci/python-smoke.mjs",
    "bench:visual-diff": "node benchmarks/visual-diff-benchmark.mjs",
    "native:visual-diff:build": "node scripts/ci/native-visual-diff-build.mjs",
    "native:visual-diff:smoke": "node scripts/ci/native-visual-diff-smoke.mjs",
    "audit": "tsx src/cli.ts audit",
    "audit:ci": "tsx src/cli.ts audit --config configs/default.json --out artifacts --baseline-dir baselines --no-fail-on-a11y",
    "case-study:fixture": "node scripts/case-study/run-fixture-case-study.mjs",
    "case-study:roi": "node scripts/case-study/roi-from-summaries.mjs",
    "case-study:provenance": "node scripts/case-study/write-provenance-manifest.mjs"
  },
  "engines": {
    "node": ">=22.19"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "chrome-launcher": "^1.1.0",
    "commander": "^14.0.3",
    "lighthouse": "^13.2.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@sentry/node": {
      "minimatch": "10.2.4"
    },
    "basic-ftp": "6.0.0",
    "yauzl": "3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.17",
    "wait-on": "^9.0.5"
  }
}
